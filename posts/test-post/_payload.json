[{"data":1,"prerenderedAt":160},["Reactive",2],{"post-/posts/test-post":3},{"_path":4,"_dir":5,"_draft":6,"_partial":6,"_locale":7,"title":8,"description":9,"link":10,"timeToRead":11,"date":12,"tags":13,"body":16,"_type":155,"_id":156,"_source":157,"_file":158,"_extension":159},"/posts/test-post","posts",false,"","Test Post Please Ignore","Testing my first post using Gridsome + Vue.js for a personal website blog","test-post",1,"2020-11-11T00:00:00.000Z",[14,15],"Life","Programming",{"type":17,"children":18,"toc":151},"root",[19,27,38,48,69,83,103,117],{"type":20,"tag":21,"props":22,"children":23},"element","p",{},[24],{"type":25,"value":26},"text","If you're seeing this post then that means the blog is working. I'll have a lot more (hopefully) great content coming soon. Just hold on.",{"type":20,"tag":21,"props":28,"children":29},{},[30,32],{"type":25,"value":31},"Just so this post has a bit of actual content. Here's an image of my old website. It was littered with typos and dead links that I didn't notice for 2 years since I never really updated it.\n",{"type":20,"tag":33,"props":34,"children":37},"img",{"alt":35,"src":36},"OLD HOMEPAGE","/posts/test-post/old_homepage.png",[],{"type":20,"tag":21,"props":39,"children":40},{},[41,43],{"type":25,"value":42},"And here's an image of the updated homepage. Looks a lot nicer. Lower quantity but higher quality projects. A unified layout across all my subpages. An integrated blog.\n",{"type":20,"tag":33,"props":44,"children":47},{"alt":45,"src":46},"NEW HOMEPAGE","/posts/test-post/new_homepage.png",[],{"type":20,"tag":21,"props":49,"children":50},{},[51,53,60,62],{"type":25,"value":52},"I've also set up sub-repositories for webapps that were originally built in this repo and redirect to those sub pages from the original links. For example the old link ",{"type":20,"tag":54,"props":55,"children":57},"a",{"href":56},"/algtrainer",[58],{"type":25,"value":59},"preethamrn.com/algtrainer",{"type":25,"value":61}," redirects to ",{"type":20,"tag":54,"props":63,"children":67},{"href":64,"rel":65},"https://www.preethamrn.com/cubing/algtrainer",[66],"nofollow",[68],{"type":25,"value":64},{"type":20,"tag":21,"props":70,"children":71},{},[72,74,81],{"type":25,"value":73},"This helps reduce the package size of the main homepage and blog posts. I'll probably write up more about how I accomplished this later (for a hint, go to the ",{"type":20,"tag":54,"props":75,"children":78},{"href":76,"rel":77},"https://github.com/preethamrn/preethamrn.com/tree/bf929583bd4a2a80e10756ce6b4ce6a29ae6721a/content/redirects",[66],[79],{"type":25,"value":80},"redirects",{"type":25,"value":82}," directory in my repo).",{"type":20,"tag":21,"props":84,"children":85},{},[86,88,101],{"type":25,"value":87},"A few things that I'm planning on doing is adding tags to all my posts, a comments section, better citation support",{"type":20,"tag":89,"props":90,"children":91},"sup",{},[92],{"type":20,"tag":54,"props":93,"children":98},{"href":94,"ariaDescribedBy":95,"dataFootnoteRef":7,"id":97},"#user-content-fn-1",[96],"footnote-label","user-content-fnref-1",[99],{"type":25,"value":100},"1",{"type":25,"value":102},", smaller image sizes, and recommended posts. Hopefully I'll have all this set up before writing my first proper blog post.",{"type":20,"tag":21,"props":104,"children":105},{},[106,108,115],{"type":25,"value":107},"In the meantime, consider following my RSS feed ",{"type":20,"tag":54,"props":109,"children":112},{"href":110,"rel":111},"https://www.preethamrn.com/feed.xml",[66],[113],{"type":25,"value":114},"here",{"type":25,"value":116},".",{"type":20,"tag":118,"props":119,"children":122},"section",{"className":120,"dataFootnotes":7},[121],"footnotes",[123,131],{"type":20,"tag":124,"props":125,"children":128},"h2",{"className":126,"id":96},[127],"sr-only",[129],{"type":25,"value":130},"Footnotes",{"type":20,"tag":132,"props":133,"children":134},"ol",{},[135],{"type":20,"tag":136,"props":137,"children":139},"li",{"id":138},"